{
  "name": "pubg-stats-service",
  "version": "1.2.0.33",
  "description": "PUBG Statistics Service",
  "main": "dist/src/index.js",
  "scripts": {
    "start": "node dist/src/index.js",
    "build": "tsc",
    "dev": "nodemon --exec ts-node src/index.ts",
    "dev:console": "CONSOLE_OUTPUT=true nodemon --exec ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:console": "CONSOLE_OUTPUT=true npm run dev",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "format:imports": "biome check --write src test scripts",
    "typecheck": "tsc --noEmit",
    "check:all": "npm run format:imports && npm run typecheck",
    "test:integration": "jest --config jest.integration.config.js",
    "update-commands": "node scripts/update-discord-commands.js",
    "version:build": "node scripts/increment-build.js",
    "version:patch": "node scripts/increment-version.js patch",
    "version:minor": "node scripts/increment-version.js minor",
    "version:major": "node scripts/increment-version.js major",
    "docker:build": "npm run build && docker build -t pubg-tracker-bot .",
    "docker:run": "docker run -p 3000:3000 pubg-tracker-bot",
    "prepare": "husky || exit 0",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@j03fr0st/pubg-ts": "^1.1.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "debug": "^4.4.3",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.24",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "prisma": "^7.4.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "undici": "6.21.1"
  }
}
